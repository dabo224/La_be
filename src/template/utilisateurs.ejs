<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Utilisateurs</title>
    <style>
        body {
            font-family: 'Segoe UI', Arial, sans-serif;
            background: #f0f2f5;
            margin: 0;
            font-size: 15px;
        }
        section {
            margin-top: 70px;
            padding: 0 2vw;
        }
        section h1 {
            text-align: left;
            font-size: 1.5em;
            color: #1877f2;
            margin: 32px 0 18px 0;
            letter-spacing: 1px;
        }
        .friend-section {
            display: flex;
            justify-content: center;
        }
        #friend {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 22px;
            width: 100%;
        }
        @media (max-width: 1200px) {
            #friend {
                grid-template-columns: repeat(3, 1fr);
            }
        }
        @media (max-width: 900px) {
            #friend {
                grid-template-columns: repeat(2, 1fr);
                gap: 16px;
            }
        }
        @media (max-width: 600px) {
            #friend {
                grid-template-columns: 1fr;
                gap: 10px;
            }
        }
        .friend-user {
            background: #fff;
            border-radius: 14px;
            box-shadow: 0 2px 10px rgba(24,119,242,0.07);
            overflow: hidden;
            display: flex;
            flex-direction: column;
            align-items: center;
            transition: box-shadow 0.2s;
            min-width: 0;
            max-width: 260px;
            margin: 0 auto;
        }
        .friend-user:hover {
            box-shadow: 0 8px 32px rgba(24,119,242,0.13);
            transform: translateY(-2px) scale(1.02);
        }
        .friend-user img {
            width: 100%;
            max-width: 120px;
            height: 120px;
            object-fit: cover;
            border-radius: 50%;
            margin-top: 22px;
            border: 3px solid #1877f2;
            background: #f0f2f5;
        }
        .bouton {
            width: 100%;
            padding: 18px 16px 12px 16px;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 10px;
        }
        .bouton p {
            font-weight: 600;
            color: #222;
            margin: 0;
            font-size: 1.1em;
            text-align: center;
        }
        .action {
            width: 100%;
            display: flex;
            gap: 10px;
            justify-content: center;
        }
        .action button {
            flex: 1;
            padding: 8px 0;
            border-radius: 8px;
            border: none;
            background: #e4e6eb;
            color: #1877f2;
            font-weight: 500;
            font-size: 1em;
            cursor: pointer;
            transition: background 0.2s, color 0.2s;
        }
        .action button:hover {
            background: #1877f2;
            color: #fff;
        }
        .action .acc_demande {
            background: #42b72a;
            color: #fff;
        }
        .action .acc_demande:hover {
            background: #36a420;
        }
        .action .ref_demande, .action .supp {
            background: #f02849;
            color: #fff;
        }
        .action .ref_demande:hover, .action .supp:hover {
            background: #c82333;
        }
        .action .voir_profil {
            background: #e4e6eb;
            color: #1877f2;
        }
        .action .voir_profil:hover {
            background: #1877f2;
            color: #fff;
        }
        .action .ajout_ami {
            background: #1877f2;
            color: #fff;
        }
        .action .ajout_ami:hover {
            background: #145db2;
        }
        .status {
            background: #42b72a;
            color: #fff;
            border-radius: 6px;
            padding: 4px 0;
            width: 100%;
            text-align: center;
            font-size: 0.95em;
            margin-top: 8px;
        }
        @media (max-width: 900px) {
            section {
                margin-top: 56px;
                padding: 0 1vw;
            }
            #friend {
                gap: 18px;
            }
            .friend-user img {
                max-width: 90px;
                height: 90px;
                margin-top: 16px;
            }
            .bouton {
                padding: 12px 8px 8px 8px;
            }
        }
        @media (max-width: 600px) {
            section {
                margin-top: 48px;
                padding: 0 2vw;
            }
            #friend {
                grid-template-columns: 1fr;
                gap: 14px;
            }
            .friend-user img {
                max-width: 70px;
                height: 70px;
                margin-top: 10px;
            }
            .bouton {
                padding: 8px 4px 6px 4px;
            }
            section h1 {
                font-size: 1.15em;
                margin: 18px 0 10px 0;
            }
        }
    </style>
</head>
<body>
    <%- include('./partials/header') %>

    <style>
        .user-nav {
            display: flex;
            flex-direction: column;
            background: #fff;
            border-radius: 16px;
            box-shadow: 0 2px 12px rgba(24,119,242,0.08);
            padding: 24px 0;
            min-width: 180px;
            margin-right: 32px;
            gap: 12px;
            position: sticky;
            top: 24px;
            height: fit-content;
        }
        .user-nav-btn {
            background: none;
            border: none;
            font-size: 1.08rem;
            font-weight: 600;
            color: #1877f2;
            padding: 12px 18px;
            border-radius: 8px;
            cursor: pointer;
            transition: background 0.2s, color 0.2s;
            text-align: left;
        }
        .user-nav-btn.active {
            background: #1877f2;
            color: #fff;
        }
        @media (max-width: 900px) {
            .user-nav {
                flex-direction: row;
                min-width: unset;
                margin-right: 0;
                margin-bottom: 18px;
                padding: 8px 0;
                justify-content: center;
                width: 100%;
                border-radius: 0;
                box-shadow: none;
            }
            .user-nav-btn {
                text-align: center;
                font-size: 1rem;
                padding: 10px 12px;
                flex: 1;
                border-radius: 0;
            }
        }
        @media (max-width: 600px) {
            .user-nav {
                flex-direction: row;
                width: 100vw;
                left: 0;
                right: 0;
                position: fixed;
                top: 0;
                z-index: 10;
                margin: 0;
                border-radius: 0;
                box-shadow: 0 2px 8px rgba(24,119,242,0.08);
                padding: 0;
            }
            .user-nav-btn {
                font-size: 0.98rem;
                padding: 10px 0;
                flex: 1;
                border-radius: 0;
            }
            section {
                margin-top: 56px !important;
            }
        }
    </style>

    <div class="friend-section">
        <div class="user-nav" id="userNav">
            <button class="user-nav-btn active" data-section="amis">Amis</button>
            <button class="user-nav-btn" data-section="attente">Demande en attente</button>
            <button class="user-nav-btn" data-section="suggestion">Suggestions</button>
        </div>
        <section style="width:100%">
            <div id="section-amis">
                <h1>Amis</h1>
                <div id="friend">
                    <% if (amis) { %>
                    <% amis.forEach(user => { %>
                        <div class="friend-user">
                            <img src="/static/profil/<%= user.Profil.urlPhoto %>" alt="">
                            <div class="bouton">
                                <p><%= user.prenom %> <%= user.nom %></p>
                                <div class="action">
                                    <% if (user.Reception) { %>
                                        <button class="acc_demande" data-friendId="<%= user.id %>">Valider Demande</button>
                                        <button class="ref_demande">Refuser</button>
                                    <% } else if(user.Envoi) { %>
                                        <button class="ann_demande" data-friendId="<%= user.id %>">Annuler demande</button>
                                        <button class="supp">Supprimer</button>
                                    <% } else if(user.Friends) { %>
                                        <button class="voir_profil" data-friendId="<%= user.id %>">Voir Profil</button>
                                        <button class="supp">Supprimer</button>
                                    <% } else { %>
                                        <button class="ajout_ami" data-friendId="<%= user.id %>">Ajouter Ami(e)</button>
                                        <button class="voir_profil">Voir Profil</button>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                    <% }); %>
                    <% } %>
                </div>
            </div>
            <div id="section-attente" style="display:none">
                <h1>Demande En Attente</h1>
                <div id="friend">
                    <% if (attentes) { %>
                    <% attentes.forEach(user => { %>
                        <div class="friend-user">
                            <img src="/static/profil/<%= user.Profil.urlPhoto %>" alt="">
                            <div class="bouton">
                                <p><%= user.prenom %> <%= user.nom %></p>
                                <div class="action">
                                    <% if (user.Reception) { %>
                                        <button class="acc_demande" data-friendId="<%= user.id %>" data-notifId="<%= user.Reception %>">Accepter</button>
                                        <button class="ref_demande" data-notifId="<%= user.Reception %>">Refuser</button>
                                    <% } else if(user.Envoi) { %>
                                        <button class="supp">Voir Profil</button>
                                        <button class="ann_demande" data-notifId="<%= user.Envoi %>" data-friendId="<%= user.id %>">Annuler</button>
                                    <% } else if(user.Friends) { %>
                                        <button class="voir_profil" data-friendId="<%= user.id %>">Voir Profil</button>
                                        <button class="supp">Supprimer</button>
                                    <% } else { %>
                                        <button class="ajout_ami" data-friendId="<%= user.id %>">Ajouter Ami(e)</button>
                                        <button class="voir_profil">Voir Profil</button>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                    <% }); %>
                    <% } %>
                </div>
            </div>
            <div id="section-suggestion" style="display:none">
                <h1>Suggestions</h1>
                <div id="friend">
                    <% if (suggestions) { %>
                    <% suggestions.forEach(user => { %>
                        <div class="friend-user">
                            <img src="/static/profil/<%= user.Profil.urlPhoto %>" alt="">
                            <div class="bouton">
                                <p><%= user.prenom %> <%= user.nom %></p>
                                <div class="action">
                                    <% if (user.Reception) { %>
                                        <button class="acc_demande" data-friendId="<%= user.id %>" data-notifId="<%= user.Reception.id %>">Valider Demande</button>
                                        <button class="ref_demande" data-notifId="<%= user.Reception.id %>">Refuser</button>
                                    <% } else if(user.Envoi) { %>
                                        <button class="ann_demande" data-friendId="<%= user.id %>">Annuler demande</button>
                                        <button class="supp">Supprimer</button>
                                    <% } else if(user.Friends) { %>
                                        <button class="voir_profil" data-friendId="<%= user.id %>">Voir Profil</button>
                                        <button class="supp">Supprimer</button>
                                    <% } else { %>
                                        <button class="ajout_ami" data-friendId="<%= user.id %>">Ajouter Ami(e)</button>
                                        <button class="voir_profil">Voir Profil</button>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                    <% }); %>
                    <% } %>
                </div>
            </div>
        </section>
        <div></div>
    </div>
        
    <script>
    // Navigation logic
    const navBtns = document.querySelectorAll('.user-nav-btn');
    const sections = {
        amis: document.getElementById('section-amis'),
        attente: document.getElementById('section-attente'),
        suggestion: document.getElementById('section-suggestion')
    };
    navBtns.forEach(btn => {
        btn.addEventListener('click', () => {
            navBtns.forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            Object.keys(sections).forEach(key => {
                sections[key].style.display = (btn.dataset.section === key) ? '' : 'none';
            });
        });
    });

    // Gestion du bouton Ajouter Ami(e)
    document.querySelectorAll('.ajout_ami').forEach(acc => {
        acc.addEventListener('click', async () => {
            const response = await fetch('/notif?demande=true', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({ userID: acc.getAttribute('data-friendId'), senderId: decode().userId })
            });
            if (response.ok) {
                alert('Demande envoyée avec succès');
            }
        });
    });
    // Gestion du bouton Refuser
    document.querySelectorAll('.ref_demande').forEach(element => {
        element.addEventListener('click', async () => {
            const response = await fetch(`/notif/${element.getAttribute('data-notifId')}`, {
                method: 'DELETE'
            });
            const result = await response.json();
            if (result.delete) {
                const parent = element.parentElement;
                const parent1 = parent.parentElement;
                parent1.parentElement.style.display = 'none';
            }
        });
    });
    // Gestion du bouton Accepter
    document.querySelectorAll('.acc_demande').forEach(element => {
        element.addEventListener('click', async () => {
            const response = await fetch('/friend', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({ friendId: element.getAttribute('data-friendId'), userId: decode().userId })
            });
            const result = await response.json();
            if (result.friend) {
                const parent = element.parentElement;
                const parent1 = parent.parentElement;
                parent1.parentElement.style.display = 'none';
                alert('Demande d\'amis acceptée avec succès');
                await fetch(`/notif/${element.getAttribute('data-notifId')}?all=true`, {
                    method: 'DELETE'
                });
            }
        });
    });
    // Gestion du bouton Annuler
    document.querySelectorAll('.ann_demande').forEach(element => {
        element.addEventListener('click', async () => {
            const response = await fetch(`/notif/${element.getAttribute('data-notifId')}?all=true`, {
                method: 'DELETE'
            });
            const result = await response.json();
            if (result.delete) {
                location.reload();
                const parent = element.parentElement;
                const parent1 = parent.parentElement;
                parent1.parentElement.style.display = 'none';
            }
        });
    });
    </script>
</body>
</html>